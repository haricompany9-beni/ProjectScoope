rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Projects collection
    match /projects/{projectId} {
      // Anyone can create a project (public submission)
      allow create: if true; // In a real app, you might want rate limiting or captcha
      
      // Admin dashboard access
      // For MVP, we use a simple check. In production, this would check an 'admins' collection.
      allow read, update, delete: if isSignedIn(); 
    }
  }
}
