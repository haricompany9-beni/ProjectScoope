{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project brief submitted by a client",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["website", "mobile"] },
        "projectName": { "type": "string" },
        "description": { "type": "string" },
        "goals": { "type": "string" },
        "targetAudience": { "type": "string" },
        "existingSolution": { "type": "string" },
        "platform": { "type": "string" },
        "pagesOrFeatures": { "type": "array", "items": { "type": "string" } },
        "brandingStatus": { "type": "string" },
        "references": { "type": "string" },
        "specificNeeds": { "type": "array", "items": { "type": "string" } },
        "budget": { "type": "string" },
        "deadline": { "type": "string" },
        "contact": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["new", "in_progress", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "projectName", "contact"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of project briefs"
    }
  }
}
